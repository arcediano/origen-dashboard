# GitHub Packages Authentication
# Required to install @arcediano/ux-library from npm.pkg.github.com
# Generate token at: https://github.com/settings/tokens
# Required scope: read:packages
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Runtime environment (optional for local development)
NODE_ENV=development

# API Gateway URL (server-side — no NEXT_PUBLIC_ needed for route handlers)
API_GATEWAY_URL=https://origen-gateway-dev.onrender.com
# Also expose it publicly for client-side rewrites (next.config.js)
NEXT_PUBLIC_API_GATEWAY_URL=https://origen-gateway-dev.onrender.com

# CDN base URL for image display (CloudFront or S3 public URL)
# Used to resolve raw S3 keys into viewable image URLs
NEXT_PUBLIC_CDN_BASE_URL=https://cdn.origen.delivery
